{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "env": {}
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time"],
      "env": {}
    },
    "web-search": {
      "command": "python3",
      "args": ["<path-to-repo>/openrouter-search-mcp.py"],
      "env": {}
    }
  }
}
